---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import RecipeCard from '../components/RecipeCard.astro';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => b.data.date.localeCompare(a.data.date));

const allTags = Array.from(new Set(recipes.flatMap(r => r.data.tags))).sort();
---
<Base title="המתכונים של דוד 📖">
  <section class="bg-gradient-to-bl from-spice-500 via-spice-600 to-spice-800 text-white">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
      <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
        המתכונים של דוד
      </h1>
      <p class="mt-4 text-lg md:text-xl text-spice-100 max-w-2xl">
        אוסף אישי של מתכונים שהכנו, נסינו ושיפרנו יחד 🦊
        כל מתכון עם פירוט תזונתי מלא, רשימת רכיבים אינטראקטיבית, וסקיילר מנות.
      </p>
      <div class="mt-8 flex items-center gap-6 text-sm text-spice-100">
        <span><strong class="text-white text-lg">{recipes.length}</strong> מתכונים</span>
        <span><strong class="text-white text-lg">{allTags.length}</strong> תגיות</span>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row gap-4 items-stretch md:items-center mb-8">
      <div class="relative flex-1">
        <input
          id="search"
          type="search"
          placeholder="חיפוש מתכון..."
          class="w-full px-4 py-3 pr-11 rounded-xl border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-900 focus:outline-none focus:ring-2 focus:ring-spice-500 focus:border-transparent text-base"
        />
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8" id="tag-filters">
        <button data-tag="" class="tag-btn active px-3 py-1.5 rounded-full text-sm font-medium border border-stone-200 dark:border-stone-700 bg-spice-600 text-white border-spice-600">
          הכל
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn px-3 py-1.5 rounded-full text-sm font-medium border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-900 hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors"
          >
            {tag}
          </button>
        ))}
      </div>
    )}

    <div id="recipe-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recipes.map(r => (
        <div class="recipe-item" data-title={r.data.title.toLowerCase()} data-tags={r.data.tags.join('|')}>
          <RecipeCard recipe={r} />
        </div>
      ))}
    </div>

    <p id="no-results" class="hidden text-center text-stone-500 dark:text-stone-400 py-16">
      לא נמצאו מתכונים תואמים 🤷
    </p>
  </section>

  <script>
    const search = document.getElementById('search') as HTMLInputElement;
    const items = Array.from(document.querySelectorAll('.recipe-item')) as HTMLElement[];
    const tagBtns = Array.from(document.querySelectorAll('.tag-btn')) as HTMLButtonElement[];
    const noResults = document.getElementById('no-results')!;
    let activeTag = '';

    function filter() {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      items.forEach(item => {
        const t = item.dataset.title || '';
        const tags = (item.dataset.tags || '').split('|');
        const matchesText = !q || t.includes(q);
        const matchesTag = !activeTag || tags.includes(activeTag);
        const show = matchesText && matchesTag;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    }

    search?.addEventListener('input', filter);
    tagBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTag = btn.dataset.tag || '';
        tagBtns.forEach(b => {
          b.classList.remove('active', 'bg-spice-600', 'text-white', 'border-spice-600');
          b.classList.add('bg-white', 'dark:bg-stone-900');
        });
        btn.classList.add('active', 'bg-spice-600', 'text-white', 'border-spice-600');
        btn.classList.remove('bg-white', 'dark:bg-stone-900');
        filter();
      });
    });
  </script>
</Base>
